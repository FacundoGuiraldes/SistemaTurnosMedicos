@startuml
title Patrón Factory Method - Sistema de Turnos Médicos (Corregido según Code Review)

' ==============================================================================
' 2.6 COMPOSITION ROOT (Punto de Ensamble - Req 2.6)
' ==============================================================================
package "Infraestructura de Inicialización" {
    class TurnosMedicosApp {
        + {static} main(args: String[]): void
    }
}

' ========================
' FACTORY PARA TURNOS
' ========================

package "Factory Method - Creación de Turnos" {

    ' INTERFAZ CREADORA - Cambiado a <<interface>> estándar (Req 2.1)
    interface ITurnoFactory <<interface>> {
        + crearTurno(fecha: LocalDate, hora: LocalTime, especialidad: Especialidad): Turno
    }

    ' CREADORES CONCRETOS - Homogeneizados los retornos a la abstracción Turno (Req 2.2)
    class TurnoPresencialFactory implements ITurnoFactory {
        - agendaConsultorios: AgendaConsultorios
        + crearTurno(fecha: LocalDate, hora: LocalTime, especialidad: Especialidad): Turno
        + validarDisponibilidadConsultorio(fecha: LocalDate): boolean
        + asignarConsultorio(): String
    }

    class TurnoVirtualFactory implements ITurnoFactory {
        - servicioVideoconferencia: ServicioVideoconferencia
        + crearTurno(fecha: LocalDate, hora: LocalTime, especialidad: Especialidad): Turno
        + generarEnlaceVideollamada(): String
        + generarCodigoAcceso(): String
        + validarDisponibilidadPlataforma(): boolean
    }

    class TurnoTelemedicinaFactory implements ITurnoFactory {
        - registroProveedores: RegistroProveedoresTelemedicina
        + crearTurno(fecha: LocalDate, hora: LocalTime, especialidad: Especialidad): Turno
        + asignarProveedorServicio(): String
        + validarCobertura(zona: String): boolean
    }

    ' PRODUCTOS ABSTRACTOS Y CONCRETOS
    abstract class Turno {
        - id: String
        - fecha: LocalDate
        - hora: LocalTime
        - estado: EstadoTurno
        - especialidad: Especialidad
        + {abstract} confirmar(): void
        + {abstract} cancelar(solicitadoPor: Usuario, motivo: String): Boolean
        + {abstract} marcarAsistencia(presentado: Boolean): void
    }

    class TurnoPresencial extends Turno {
        - numeroConsultorio: String
        - pisoEdificio: Integer
        + confirmar(): void
        + cancelar(solicitadoPor: Usuario, motivo: String): Boolean
        + marcarAsistencia(presentado: Boolean): void
    }

    class TurnoVirtual extends Turno {
        - enlaceVideollamada: String
        - codigoAcceso: String
        - plataforma: String
        + confirmar(): void
        + cancelar(solicitadoPor: Usuario, motivo: String): Boolean
        + marcarAsistencia(presentado: Boolean): void
        + enviarEnlaceAlPaciente(): void
    }

    class TurnoTelemedicina extends Turno {
        - idProveedor: String
        - direccionPaciente: String
        - equipoMedico: List<String>
        + confirmar(): void
        + cancelar(solicitadoPor: Usuario, motivo: String): Boolean
        + marcarAsistencia(presentado: Boolean): void
        + coordinarVisitaDomiciliaria(): void
    }

    ' RELACIONES UNIFICADAS -> Todas con dependencia punteada ..> (Req 2.3)
    ITurnoFactory ..> Turno : crea
    TurnoPresencialFactory ..> TurnoPresencial : produce
    TurnoVirtualFactory ..> TurnoVirtual : produce
    TurnoTelemedicinaFactory ..> TurnoTelemedicina : produce
}

' ========================
' FACTORY PARA NOTIFICACIONES
' ========================

package "Factory Method - Creación de Notificaciones" {

    ' INTERFAZ CREADORA - Cambiado a <<interface>> estándar (Req 2.1)
    interface INotificacionFactory <<interface>> {
        + crearNotificacion(destinatario: String, mensaje: String): Notificacion
    }

    ' CREADORES CONCRETOS - Homogeneizados los retornos a la abstracción Notificacion (Req 2.2)
    class EmailNotificacionFactory implements INotificacionFactory {
        - servidorSMTP: ServidorSMTP
        + crearNotificacion(destinatario: String, mensaje: String): Notificacion
        + validarEmail(email: String): boolean
    }

    class SMSNotificacionFactory implements INotificacionFactory {
        - proveedorSMS: ProveedorSMS
        + crearNotificacion(destinatario: String, mensaje: String): Notificacion
        + validarTelefono(numero: String): boolean
        + calcularCosto(): Double
    }

    class WhatsAppNotificacionFactory implements INotificacionFactory {
        - apiWhatsApp: APIWhatsApp
        + crearNotificacion(destinatario: String, mensaje: String): Notificacion
        + validarNumeroWhatsApp(numero: String): boolean
    }

    class PushNotificacionFactory implements INotificacionFactory {
        - servicioNotificaciones: ServicioPush
        + crearNotificacion(destinatario: String, mensaje: String): Notificacion
        + validarDispositivoRegistrado(usuarioId: String): boolean
    }

    ' PRODUCTOS ABSTRACTOS Y CONCRETOS
    abstract class Notificacion {
        - id: String
        - destinatario: String
        - mensaje: String
        - estado: String
        - fechaEnvio: LocalDateTime
        + {abstract} enviar(): boolean
        + {abstract} validarDestinatario(): boolean
        + programarEnvio(fecha: LocalDateTime): void
    }

    class EmailNotificacion extends Notificacion {
        - email: String
        - asunto: String
        - contenidoHTML: String
        + enviar(): boolean
        + validarDestinatario(): boolean
    }

    class SMSNotificacion extends Notificacion {
        - numeroCelular: String
        - longitudMensaje: Integer
        + enviar(): boolean
        + validarDestinatario(): boolean
        + fragmentarMensajeLargo(): List<String>
    }

    class WhatsAppNotificacion extends Notificacion {
        - numeroWhatsApp: String
        - tipoMensaje: String
        - urlMedia: String
        + enviar(): boolean
        + validarDestinatario(): boolean
        + enviarMediaAdjunto(tipo: String, url: String): void
    }

    class PushNotificacion extends Notificacion {
        - idDispositivo: String
        - tituloNotificacion: String
        - accionAsociada: String
        + enviar(): boolean
        + validarDestinatario(): boolean
    }

    ' RELACIONES UNIFICADAS -> Todas con dependencia punteada ..> (Req 2.3)
    INotificacionFactory ..> Notificacion : crea
    EmailNotificacionFactory ..> EmailNotificacion : produce
    SMSNotificacionFactory ..> SMSNotificacion : produce
    WhatsAppNotificacionFactory ..> WhatsAppNotificacion : produce
    PushNotificacionFactory ..> PushNotificacion : produce
}

' ========================
' CLASES DEL SISTEMA REFACTORIZADAS
' ========================

package "Sistema Desacoplado" {

    class Sistema {
        - turnoFactory: ITurnoFactory
        - notificacionFactory: INotificacionFactory
        + Sistema(turnoFactory: ITurnoFactory, notificacionFactory: INotificacionFactory)
        + solicitarTurno(fecha: LocalDate, hora: LocalTime, especialidad: Especialidad): Turno
        ' Sincronizada la firma críticamente agregando hora y especialidad (Req 2.4)
        + registrarTurno(paciente: Paciente, doctor: Doctor, fecha: LocalDate, hora: LocalTime, especialidad: Especialidad): Turno
        + enviarRecordatorioAutomatico(paciente: Paciente, turno: Turno): void
        ' Se eliminó setTurnoFactory() para evitar violación de inyección pura (Req 2.5)
    }

    class Secretaria {
        - turnoFactory: ITurnoFactory
        + Secretaria(turnoFactory: ITurnoFactory)
        + programarTurno(paciente: Paciente, fecha: LocalDate, hora: LocalTime, especialidad: Especialidad): Turno
        + registrarPaciente(datos: Map<String, String>): Paciente
    }

    class ServicioNotificaciones {
        - notificacionFactory: INotificacionFactory
        + ServicioNotificaciones(factory: INotificacionFactory)
        + enviarNotificacion(canal: String, destinatario: String, mensaje: String): boolean
        ' Se eliminó setFactory() para evitar violación de inyección pura (Req 2.5)
    }

    ' RELACIONES CON FACTORIES
    Sistema --> ITurnoFactory : inyecta
    Sistema --> INotificacionFactory : inyecta
    Secretaria --> ITurnoFactory : usa
    ServicioNotificaciones --> INotificacionFactory : usa
}

' ==============================================================================
' ENSAMBLE DEL SYSTEMA (Req 2.6)
' ==============================================================================
TurnosMedicosApp ..> TurnoPresencialFactory : instancializa
TurnosMedicosApp ..> EmailNotificacionFactory : instancializa
TurnosMedicosApp ..> Sistema : inyecta-dependencias-en

' ========================
' NOTAS
' ========================

note right of ITurnoFactory
    **Factory Creator**
    Define contrato para crear turnos
    de cualquier tipo sin acoplamiento
end note

note right of INotificacionFactory
    **Factory Creator**
    Define contrato para crear
    notificaciones por cualquier canal
end note

note top of Sistema
    **Cliente Desacoplado**
    Recibe factories inyectadas
    No instancia directamente
end note

@enduml